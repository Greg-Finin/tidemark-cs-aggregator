# Anthropic — required for the chat sidebar and "Suggest next step" button.
# Without this set, those features render an "API key not configured" state and
# the rest of the app works.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Fake auth — the demo's /login button signs you in as this CSM. Match a
# csm_owner value from lib/csm.ts.
DEMO_CSM=Greg Finin
